%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 43af71a745db8cf49984c234f252689c, type: 3}
  m_Name: Dlg_Ch2_Home
  m_EditorClassIdentifier: Assembly-CSharp::ShadowSeller.Core.DialogueData
  lines:
  - speakerName: 
    text: "... ...."
  - speakerName: 
    text: "\uADF8 \uB0A0 \uC774\uD6C4, \uD398\uD130\uC758 \uC0B6\uC740 \uBC14\uB00C\uC5C8\uB2E4."
  - speakerName: 
    text: "\uD765\uCCAD\uB9DD\uCCAD \uB3C8\uC744 \uC368\uB3C4 \uB9C8\uC220 \uC8FC\uBA38\uB2C8\uC5D0\uC11C\uB294
      \uB04A\uC784\uC5C6\uC774 \uAE08\uD654\uAC00 \uC3DF\uC544\uC84C\uB2E4."
  - speakerName: 
    text: "\uC88B\uC740 \uC9D1, \uC88B\uC740 \uC74C\uC2DD, \uC88B\uC740 \uC637, \uADF8\uB294
      \uB9D0 \uADF8\uB300\uB85C \uBD80\uC871\uD568 \uC5C6\uB294 \uC0B6\uC744 \uC0B4\uACE0
      \uC788\uC5C8\uB2E4."
  - speakerName: 
    text: "... ...."
  - speakerName: 
    text: "\uCFF5! \uCFF5!"
  - speakerName: "\uBCA4\uB378 \uD638\uD504\uB9CC"
    text: "\uC774\uBD10, \uD398\uD130! \uC9C0\uAE08 \uC9D1\uC5D0 \uC788\uC9C0? \uBB38
      \uC880 \uC5F4\uC5B4\uBD10!!"
  - speakerName: 
    text: "\uC870\uC6A9\uD558\uB2E4."
  - speakerName: 
    text: "\uBB38\uC744 \uB450\uB4DC\uB9AC\uB358 \uADF8\uB294 \uC606\uC758 \uC6B0\uCCB4\uD1B5\uC744
      \uD655\uC778\uD55C\uB2E4. \uD55C\uB3D9\uC548 \uAC74\uB4E4\uC9C0 \uC54A\uC740
      \uAC83\uC778\uC9C0 \uC6B0\uCCB4\uD1B5\uC740 \uBA3C\uC9C0\uAC00 \uC870\uAE08
      \uC313\uC5EC \uC788\uB2E4."
  - speakerName: "\uBCA4\uB378 \uD638\uD504\uB9CC"
    text: "\uCD9C\uC7A5\uC744 \uB2E4\uB140\uC640\uC11C \uCE5C\uAD6C \uC5BC\uAD74\uC744
      \uC78A\uC5B4\uBC84\uB9B0 \uAC74\uC9C0 \uD761\uD608\uADC0\uAC00 \uB418\uC11C
      \uD587\uBE5B\uC744 \uBABB \uBCF4\uB294 \uAC74\uC9C0 \uBD84\uAC04\uC774 \uC548
      \uB418\uB294\uAD70!"
  - speakerName: "\uBCA4\uB378 \uD638\uD504\uB9CC"
    text: "\uCD9C\uC7A5 \uB54C\uBB38\uC5D0 \uBA40\uB9AC \uB2E4\uB140\uC654\uB2E4\uBA74\uC11C!
      \uBA40\uB9AC \uB2E4\uB140\uC654\uC73C\uBA74 \uCE5C\uAD6C \uC5BC\uAD74\uC740
      \uBCF4\uB7EC \uB098\uC640\uC57C\uC9C0!"
  - speakerName: 
    text: "\uC5EC\uC804\uD788 \uBC18\uC751\uC774 \uC5C6\uC790 \uADF8\uB294 \uC6B0\uCCB4\uD1B5\uC744
      \uC5F4\uC5B4 \uC678\uB85C\uC774 \uC549\uC544 \uC788\uB294 \uD3B8\uC9C0 \uD558\uB098\uB97C
      \uAEBC\uB0B8\uB2E4. \uADF8\uB9AC\uACE0 \uC790\uC2E0\uC758 \uC18C\uB9E4\uC5D0\uC11C
      \uB2E4\uB978 \uD3B8\uC9C0\uB97C \uAEBC\uB0B4\uACE4 \uBB38 \uC55E\uC5D0 \uB193\uB294\uB2E4."
  - speakerName: "\uBCA4\uB378 \uD638\uD504\uB9CC"
    text: "\uBD80\uC790\uAC00 \uB410\uB2E4\uB2C8 \uCD95\uD558\uB294 \uD558\uB294\uB370
      \uC5BC\uAD74\uC774\uB77C\uB3C4 \uBE44\uCDB0\uC8FC\uAC8C. \uC0B4\uC558\uB098
      \uC8FD\uC5C8\uB098\uB294 \uC54C\uC544\uC57C\uC9C0."
  - speakerName: 
    text: "\uD604\uAD00\uC774 \uC870\uC6A9\uD574\uC9C0\uC790 \uACE7 \uBB38\uC774
      \uC2AC\uCA4D \uC5F4\uB9B0\uB2E4."
  - speakerName: 
    text: "\uC190 \uD558\uB098\uAC00 \uB098\uC640 \uBC14\uB2E5\uC5D0 \uB193\uC778
      \uD3B8\uC9C0 \uB450 \uD1B5\uC744 \uAC00\uC838\uAC04\uB2E4."
  - speakerName: 
    text: "\uD398\uD130\uB294 \uBD09\uD22C\uCE7C\uC744 \uAEBC\uB0B4 \uBD09\uB78D\uC744
      \uB72F\uACE0 \uBD09\uD22C\uB97C \uC5F4\uC5B4 \uBCF4\uC558\uB2E4."
  - speakerName: "\uB098"
    text: "\uB77C\uC2A4\uCE7C \uBC31\uC791\uAC00 \uC0AC\uAD50 \uBB34\uB3C4\uD68C\uB77C...."
  - speakerName: 
    text: "\uC560\uCD08\uC5D0 \uB3C8 \uB9CE\uC740 \uC0AC\uB78C\uB4E4\uACFC \uC5B4\uC6B8\uB9AC\uACA0\uB2E4\uB294
      \uC0DD\uAC01\uC744 \uD574\uBCF8 \uC801\uB3C4 \uC5C6\uB294 \uD398\uD130\uB294
      \uACE0\uAC1C\uB97C \uC800\uC5C8\uB2E4."
  - speakerName: 
    text: "\uC11C\uB85C\uC5D0\uAC8C \uBE44\uC704\uB97C \uB9DE\uCDB0\uC8FC\uACE0 \uB4E3\uAE30
      \uC88B\uC740 \uB9D0\uB9CC \uD558\uB294 \uBD80\uC790\uB4E4\uC758 \uC790\uB9AC\uB294
      \uB098\uC5D0\uAC8C \uC5B4\uC6B8\uB9AC\uC9C0 \uC54A\uB2E4\uACE0 \uC0DD\uAC01\uD588\uB2E4."
  - speakerName: 
    text: "\uCD08\uB300\uC7A5\uC744 \uC544\uBB34\uB807\uC9C0 \uC54A\uAC8C \uBC14\uB2E5\uC5D0
      \uD758\uB9AC\uACE0 \uD070 \uAE30\uB300\uB97C \uD558\uC9C0 \uC54A\uC740 \uCC44
      \uB2E4\uC74C \uD3B8\uC9C0\uC758 \uBD09\uB78D\uC744 \uB72F\uC5C8\uB2E4."
  - speakerName: "\uB098"
    text: "\uBBF8\uB098 \uD3F0 \uBCA0\uB974\uD06C...."
  - speakerName: 
    text: "\uD398\uD130\uC758 \uB208\uC774 \uD718\uB465\uADF8\uB808\uC84C\uB2E4."
  - speakerName: 
    text: "\uC624\uB79C \uC18C\uAFC9\uCE5C\uAD6C\uC774\uC790 \uC5B4\uB9B0 \uC2DC\uC808\uC758
      \uCD94\uC5B5\uC744 \uACF5\uC720\uD55C \uC5EC\uC131\uC758 \uD3B8\uC9C0."
  - speakerName: 
    text: "\uC131\uC778\uC774 \uB41C \uC774\uD6C4\uC5D0\uB294 \uD604\uC2E4\uC5D0
      \uCE58\uC5EC \uC790\uC8FC \uB9CC\uB098\uC9C0 \uBABB\uD574 \uD639\uC2DC\uB098
      \uC790\uC2E0\uC744 \uC78A\uC740 \uAC74 \uC544\uB2C8\uC9C0 \uAC71\uC815\uD558\uACE0
      \uC788\uB358 \uCC28\uC600\uB2E4."
  - speakerName: 
    text: "\uC5B4\uCA4C\uBA74 \uCE5C\uAD6C \uC774\uC0C1\uC758 \uAD00\uACC4\uB85C
      \uBC1C\uC804\uD560 \uC218 \uC788\uC5C8\uC9C0\uB9CC \uD604\uC2E4\uC758 \uBCBD\uC5D0
      \uAC00\uB85C\uB9C9\uD600 \uADF8\uB7EC\uC9C0 \uBABB\uD588\uB2E4."
  - speakerName: 
    text: "\uD558\uC9C0\uB9CC \uBD80\uB97C \uAC00\uC9C4 \uC9C0\uAE08\uC774\uB77C\uBA74
      \uAC00\uB2A5\uD558\uB9AC\uB77C, \uD398\uD130\uB294 \uADF8\uB807\uAC8C \uC0DD\uAC01\uD588\uB2E4."
  - speakerName: "\uBBF8\uB098 \uD3F0 \uBCA0\uB974\uD06C"
    text: "(\uC624\uB7AB\uB3D9\uC548 \uC5F0\uB77D\uC774 \uC5C6\uC5B4 \uAC71\uC815\uD588\uC5B4\uC694.)"
  - speakerName: "\uBBF8\uB098 \uD3F0 \uBCA0\uB974\uD06C"
    text: "(\uC804 \uC774\uBC88\uC5D0 \uC131\uC778\uC774 \uB418\uC5B4 \uB77C\uC2A4\uCE7C
      \uBC31\uC791\uB2D8\uC758 \uBB34\uB3C4\uD68C\uC5D0 \uAC00\uAC8C \uB418\uC5C8\uB2F5\uB2C8\uB2E4.
      \uC544\uBC84\uC9C0\uAC00 \uAD8C\uC720\uD558\uC168\uC5B4\uC694.)"
  - speakerName: "\uBBF8\uB098 \uD3F0 \uBCA0\uB974\uD06C"
    text: "(\uBB34\uB3C4\uD68C \uC774\uD6C4\uC5D0\uB294 \uB9CE\uC774 \uBC14\uBE60\uC9C8
      \uAC83 \uAC19\uC544\uC694. \uADF8\uB807\uAC8C \uBC14\uBE60\uC9C0\uAE30 \uC804\uC5D0
      \uB2F9\uC2E0\uC744 \uB9CC\uB098\uBCF4\uACE0 \uC2F6\uC5B4\uC694.)"
  - speakerName: 
    text: "\uD398\uD130\uB294 \uB9DD\uC124\uC774\uC9C0 \uC54A\uACE0 \uC989\uC2DC
      \uC7A5\uB871\uC744 \uC5F4\uC5C8\uB2E4."
  - speakerName: 
    text: "\uADF8\uAC00 \uBC16\uC744 \uB098\uAC00\uC9C0 \uC54A\uC740 \uAC74 \uB2E8\uC21C\uD788
      \uB098\uAC00\uACE0 \uC2F6\uC9C0 \uC54A\uC558\uAE30 \uB54C\uBB38\uB9CC\uC740
      \uC544\uB2C8\uC5C8\uB2E4."
  - speakerName: 
    text: "\uADF8\uB9BC\uC790\uAC00 \uC5C6\uB2E4."
  - speakerName: 
    text: "\uADF8\uB9BC\uC790\uAC00 \uC5C6\uB2E4\uB294 \uC0AC\uC2E4\uC740 \uADF8\uB97C
      \uBD88\uC548\uD558\uAC8C \uB9CC\uB4E4\uC5C8\uB2E4."
  - speakerName: 
    text: "\uADF8\uB9BC\uC790\uAC00 \uC5C6\uB294 \uC0AC\uB78C\uC744 \uBCF4\uBA74
      \uC5B4\uB5BB\uAC8C \uBC18\uC751\uD560\uAE4C? \uADF8\uB9BC\uC790\uAC00 \uC5C6\uB294
      \uAC74 \uC5B4\uB5A4 \uAC78 \uC758\uBBF8\uD560\uAE4C?"
  - speakerName: 
    text: "\uD68C\uC0C9 \uB0A8\uC790\uC640\uC758 \uAC70\uB798\uB294 \uADF8\uC5D0\uAC8C
      \uBD80\uB97C \uC548\uACA8\uB2E4 \uC8FC\uC5C8\uC9C0\uB9CC \uB3D9\uC2DC\uC5D0
      \uB9C9\uC5F0\uD55C \uBD88\uC548\uAC10 \uC5ED\uC2DC \uC120\uC0AC\uD574\uC8FC\uC5C8\uB2E4."
  - speakerName: 
    text: "\uADF8\uB7F0 \uBD88\uC548\uAC10\uC744 \uC548\uACE0 \uAD73\uC774 \uBC16\uC744
      \uB098\uAC08 \uC774\uC720\uB294 \uC5C6\uC5C8\uB2E4. \uADF8\uB798\uC11C \uADF8\uB294
      \uB098\uAC00\uC9C0 \uC54A\uC558\uB2E4."
  - speakerName: 
    text: "\uADF8\uB7EC\uB098 \uBC29\uAE08 \uADF8\uC5D0\uAC8C \uBC16\uC744 \uB098\uAC08
      \uC774\uC720\uAC00 \uC0DD\uACBC\uB2E4."
  - speakerName: 
    text: "\uADF8\uB294 \uC790\uC2E0\uC774 \uAC00\uC9C0\uACE0 \uC788\uB294 \uC637
      \uC911, \uAC00\uC7A5 \uBE44\uC2FC \uC637\uC744 \uAEBC\uB0C8\uB2E4."
  - speakerName: 
    text: "\uADF8\uB9AC\uACE0 \uCD08\uB300\uC7A5\uC744 \uCC59\uACBC\uB2E4."
