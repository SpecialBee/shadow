--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 43af71a745db8cf49984c234f252689c, type: 3}
  m_Name: Dlg_Ch4_Warehouse
  m_EditorClassIdentifier: Assembly-CSharp::ShadowSeller.Core.DialogueData
  lines:
  - speakerName: 
    text: "\uADF8 \uC548\uC740 \uC5B4\uB461\uACE0 \uC2B5\uD588\uB2E4."
  - speakerName: 
    text: "\uB0C4\uC0C8\uB3C4 \uADF8\uB9AC \uC88B\uC740 \uACF3\uC740 \uC544\uB2C8\uC5C8\uB2E4."
  - speakerName: 
    text: "\uCC3D\uACE0 \uB0B4\uBD80 \uCC9C\uC7A5\uC758 \uC791\uC740 \uAE30\uB984\uB4F1
      \uD558\uB098\uB9CC\uC774 \uADF8\uB97C \uC678\uB86D\uAC8C \uBE44\uCD94\uACE0
      \uC788\uC5C8\uB2E4."
  - speakerName: "\uB098"
    text: "\uC544\uC9C1 \uB9CC\uB098\uC9C0\uB3C4 \uBABB\uD588\uB294\uB370...."
  - speakerName: 
    text: "\uC190 \uB05D\uC5D0 \uB2FF\uC744 \uBED4\uD55C \uBBF8\uB098\uAC00 \uB5A0\uC624\uB978\uB2E4."
  - speakerName: 
    text: "\uBD99\uC7A1\uD790 \uBED4\uD55C \uBC29\uAE08\uC758 \uC0C1\uD669\uBCF4\uB2E4"
  - speakerName: 
    text: "\uD639\uC2DC\uB098 \uBBF8\uB098\uAC00 \uC790\uC2E0\uC744 \uC624\uD574\uD558\uBA74
      \uC5B4\uCA4C\uB098 \uD558\uB294 \uBD88\uC548\uAC10\uC774 \uBA3C\uC800 \uC5C4\uC2B5\uD55C\uB2E4."
  - speakerName: 
    text: "\uB098\uB97C \uBCF8 \uAC74 \uC544\uB2CC\uAC00?"
  - speakerName: 
    text: "\uD639\uC2DC \uBBF8\uB098\uB3C4 \uB2E4\uB978 \uC0AC\uB78C\uB4E4\uCC98\uB7FC
      \uB098\uB97C \uC0DD\uAC01\uD558\uB294 \uAC74 \uC544\uB2D0\uAE4C?"
  - speakerName: 
    text: "\uC790\uC2E0\uC744 \uC624\uD574\uD558\uB294 \uAC74 \uC544\uB2D0\uAE4C?"
  - speakerName: 
    text: "\uD558\uC9C0\uB9CC \uBC14\uAE65\uC758 \uC0C1\uD669\uC740 \uAC00\uD639\uD558\uB2E4."
  - speakerName: 
    text: "\uBD84\uBA85 \uADF8\uB9BC\uC790\uAC00 \uC5C6\uB294 \uC774\uB97C \uCC3E\uC544\uB0B4\uAE30
      \uC704\uD574 \uB2E4\uB4E4 \uBC14\uC058\uAC8C \uC6C0\uC9C1\uC774\uACE0 \uC788\uC744
      \uAC83\uC774\uB2E4."
  - speakerName: 
    text: "\uACE0\uBBFC \uC911\uC774\uB358 \uD398\uD130\uB294 \uBB38\uC774 \uC5F4\uB9AC\uB294
      \uC18C\uB9AC\uC5D0 \uC228\uC744 \uCC38\uC558\uB2E4."
  - speakerName: "\uACBD\uBE44"
    text: "... \uC544\uBB34\uAC83\uB3C4 \uC548 \uBCF4\uC774\uB294\uAD70."
  - speakerName: "\uD558\uC778"
    text: "\uAC70, \uC6B0\uB9AC\uAC00 \uC5EC\uAE30 \uB4E4\uB77D\uB0A0\uB77D \uAC70\uB9AC\uACE0
      \uC788\uB294\uB370 \uC5EC\uAE30 \uC228\uACA0\uC18C?"
  - speakerName: "\uACBD\uBE44"
    text: "\uADF8\uAC70\uC57C \uADF8\uB807\uC9C0\uB9CC \uD639\uC2DC \uBAA8\uB974\uC796\uC18C."
  - speakerName: "\uD558\uC778"
    text: "\uC544\uBB34\uD2BC \uBCF4\uB2E4\uC2DC\uD53C \uAC1C\uBBF8 \uC0C8\uB07C
      \uD55C \uB9C8\uB9AC \uC5C6\uC18C."
  - speakerName: "\uACBD\uBE44"
    text: "\uC5BC\uAD74\uC774\uB77C\uB3C4 \uBD24\uC73C\uBA74 \uBAA8\uB974\uACA0\uB294\uB370
      \uADC0\uC871 \uB098\uC73C\uB9AC\uB4E4\uC740 \uD558\uB098 \uAC19\uC774 \uAE30\uC5B5\uC774
      \uC548 \uB09C\uB2E4\uACE0 \uD558\uB2C8, \uC774\uAC70 \uC6D0...."
  - speakerName: "\uACBD\uBE44"
    text: "\uBC31\uC791\uB2D8\uAED8\uC11C \uADF8\uB9BC\uC790\uAC00 \uC5C6\uB294 \uC774\uB97C
      \uAF2D \uC7A1\uC73C\uB77C\uACE0 \uD558\uC168\uC73C\uB2C8 \uADF8 \uCABD \uC0AC\uB78C\uB4E4\uD55C\uD14C\uB3C4
      \uB9D0\uD574\uB450\uC2DC\uC624."
  - speakerName: "\uD558\uC778"
    text: "\uB0B4 \uBCF4\uBA74 \uC3DC\uC0B4\uAC19\uC774 \uB2EC\uB824\uAC00 \uC598\uAE30\uD574\uB4DC\uB9B4\uD14C\uB2C8
      \uC774\uC81C \uADF8\uB9CC \uBB38 \uC880 \uB2EB\uC73C\uC1FC. \uB0C4\uC0C8 \uB2E4
      \uB098\uC624\uACA0\uC18C."
  - speakerName: 
    text: "\uBB38\uC740 \uB2E4\uC2DC \uB2EB\uD78C\uB2E4."
  - speakerName: 
    text: "\uADF8\uB294 \uAC00\uB9CC\uD788 \uAE30\uB984\uB4F1\uC744 \uC751\uC2DC\uD588\uB2E4."
  - speakerName: "\uB098"
    text: "... \uC801\uC5B4\uB3C4 \uB0B4 \uC5BC\uAD74\uC744 \uC544\uB294
      \uC774\uB4E4\uC740 \uC5C6\uB098\uBCF4\uAD70."
  - speakerName: "\uB098"
    text: "\uADF8\uB807\uB2E4\uBA74 \uC637\uB9CC \uC870\uAE08 \uAC08\uC544 \uC785\uACE0
      \uADF8\uB9BC\uC790\uAC00 \uC5C6\uB294 \uAC83\uB9CC \uB4E4\uD0A4\uC9C0 \uC54A\uB294\uB2E4\uBA74...."
  - speakerName: "\uB098"
    text: "... \uC544."
