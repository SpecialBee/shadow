MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 43af71a745db8cf49984c234f252689c, type: 3}
  m_Name: Dlg_Ch1_Frontdoor
  m_EditorClassIdentifier: Assembly-CSharp::ShadowSeller.Core.DialogueData
  lines:
  - speakerName: "\uBCA4\uB378 \uD638\uD504\uB9CC"
    text: "\uC774\uBD10, \uD398\uD130! \uC9C0\uAE08 \uC9D1\uC5D0 \uC788\uC9C0? \uBB38
      \uC880 \uC5F4\uC5B4\uBD10!!"
  - speakerName: 
    text: "\uC870\uC6A9\uD558\uB2E4."
  - speakerName: 
    text: "\uBB38\uC744 \uB450\uB4DC\uB9AC\uB358 \uADF8\uB294 \uC606\uC758 \uC6B0\uCCB4\uD1B5\uC744
      \uD655\uC778\uD55C\uB2E4. \uD55C\uB3D9\uC548 \uAC74\uB4E4\uC9C0 \uC54A\uC740
      \uAC83\uC778\uC9C0 \uC6B0\uCCB4\uD1B5\uC740 \uBA3C\uC9C0\uAC00 \uC870\uAE08
      \uC313\uC5EC \uC788\uB2E4."
  - speakerName: "\uBCA4\uB378 \uD638\uD504\uB9CC"
    text: "\uCD9C\uC7A5\uC744 \uB2E4\uB140\uC640\uC11C \uCE5C\uAD6C \uC5BC\uAD74\uC744
      \uC78A\uC5B4\uBC84\uB9B0 \uAC74\uC9C0 \uD761\uD608\uADC0\uAC00 \uB418\uC11C
      \uD587\uBE5B\uC744 \uBABB \uBCF4\uB294 \uAC74\uC9C0 \uBD84\uAC04\uC774 \uC548
      \uB418\uB294\uAD70!"
  - speakerName: "\uBCA4\uB378 \uD638\uD504\uB9CC"
    text: "\uCD9C\uC7A5 \uB54C\uBB38\uC5D0 \uBA40\uB9AC \uB2E4\uB140\uC654\uB2E4\uBA74\uC11C!
      \uBA40\uB9AC \uB2E4\uB140\uC654\uC73C\uBA74 \uCE5C\uAD6C \uC5BC\uAD74\uC740
      \uBCF4\uB7EC \uB098\uC640\uC57C\uC9C0!"
  - speakerName: 
    text: "\uC5EC\uC804\uD788 \uBC18\uC751\uC774 \uC5C6\uC790 \uADF8\uB294 \uC6B0\uCCB4\uD1B5\uC744
      \uC5F4\uC5B4 \uC678\uB85C\uC774 \uC549\uC544 \uC788\uB294 \uD3B8\uC9C0 \uD558\uB098\uB97C
      \uAEBC\uB0B8\uB2E4. \uADF8\uB9AC\uACE0 \uC790\uC2E0\uC758 \uC18C\uB9E4\uC5D0\uC11C
      \uB2E4\uB978 \uD3B8\uC9C0\uB97C \uAEBC\uB0B4\uACE4 \uBB38 \uC55E\uC5D0 \uB193\uB294\uB2E4."
  - speakerName: "\uBCA4\uB378 \uD638\uD504\uB9CC"
    text: "\uBD80\uC790\uAC00 \uB410\uB2E4\uB2C8 \uCD95\uD558\uB294 \uD558\uB294\uB370
      \uC5BC\uAD74\uC774\uB77C\uB3C4 \uBE44\uCDB0\uC8FC\uAC8C. \uC0B4\uC558\uB098
      \uC8FD\uC5C8\uB098\uB294 \uC54C\uC544\uC57C\uC9C0."
