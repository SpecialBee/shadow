  m_Script: {fileID: 11500000, guid: 43af71a745db8cf49984c234f252689c, type: 3}
  m_Name: Dlg_Ch3_MansionEntry
  m_EditorClassIdentifier: Assembly-CSharp::ShadowSeller.Core.DialogueData
  lines:
  - speakerName: 
    text: "\uADF8\uB294 \uC790\uC5F0\uC2A4\uB7FD\uAC8C \uC800\uD0DD \uB0B4\uBD80\uC5D0
      \uC785\uC131\uD588\uB2E4."
  - speakerName: 
    text: "\uC790\uC5F0\uC2A4\uB7FD\uAC8C \uCD08\uB300\uC7A5\uC744 \uBCF4\uC5EC\uC8FC\uACE0
      \uC800\uD0DD \uB0B4\uBD80\uB85C \uB4E4\uC5B4\uC130\uB2E4."
  - speakerName: 
    text: "\uACE0\uAE09\uC2A4\uB7EC\uC6B4 \uB4DC\uB808\uC2A4\uC640 \uC815\uC7A5,
      \uB3C8\uC774 \uB9CE\uAC70\uB098 \uC9C0\uC704\uAC00 \uB192\uC740 \uC774\uB4E4\uC774
      \uBC14\uAE00\uAC70\uB9AC\uB294 \uC7A5\uC18C."
  - speakerName: 
    text: "\uD654\uB824\uD55C \uC0F9\uB4E4\uB9AC\uC5D0\uC640 \uC0AC\uCE58\uC2A4\uB7EC\uC6B4
      \uBCBD\uC9C0 \uC544\uB798, \uB9CE\uC740 \uC774\uB4E4\uC774 \uBB34\uB3C4\uD68C\uB97C
      \uC990\uAE30\uACE0 \uC788\uC5C8\uB2E4."
  - speakerName: 
    text: "\uC5B4\uCC28\uD53C \uC548\uBA74\uC744 \uD2BC \uC774\uB4E4\uB07C\uB9AC
      \uB300\uD654\uD558\uB290\uB77C \uC815\uC2E0\uC774 \uC5C6\uB2E4."
  - speakerName: 
    text: "\uBBF8\uB098\uB294 \uC5B4\uB514\uC5D0 \uC788\uC744\uAE4C, \uB098\uB294
      \uADF8\uB4E4 \uC0AC\uC774\uB97C \uB3CC\uC544\uB2E4\uB2C8\uBA70 \uADF8\uB140\uB97C
      \uCC3E\uC544 \uB2E4\uB154\uB2E4."
  - speakerName: "\uB098"
    text: "(\uC774\uBC88\uC5D0 \uC0AC\uAD50\uACC4 \uCCAB \uBB34\uB3C4\uD68C\uB2C8
      \uC8FC\uC778\uACF5\uC774\uACA0\uC9C0? \uC544\uB9C8 \uC911\uC559\uC5D0 \uC788\uC9C0
      \uC54A\uC744\uAE4C?)"
